# Database
POSTGRES_USER=backtest
POSTGRES_PASSWORD=backtest_secret
POSTGRES_DB=equity_backtest
DATABASE_URL=postgresql://backtest:backtest_secret@localhost:5432/equity_backtest

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# API
LOG_LEVEL=INFO
RATE_LIMIT=100/minute
CORS_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Server-side proxy target (Next.js rewrites)
BACKEND_URL=http://127.0.0.1:8000

JWT_SECRET_KEY=change-this-secret-key-in-production

# Vercel deployment (set in Project Settings > Environment Variables)
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
# CORS_ORIGINS=https://your-app.vercel.app
# BACKEND_URL=https://your-app.vercel.app/_/backend
